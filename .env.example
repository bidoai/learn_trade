# Trading System — Environment Variables
# Copy this to .env and fill in your Alpaca credentials.
# NEVER commit .env to git.

# Alpaca paper trading credentials
# Get these from: https://alpaca.markets → Paper Trading → API Keys
ALPACA__API_KEY=your_api_key_here
ALPACA__SECRET_KEY=your_secret_key_here
ALPACA__BASE_URL=https://paper-api.alpaca.markets

# Symbols to trade (comma-separated in the .env won't work with pydantic —
# set this in config/settings.py directly, or override as a JSON list)
# ALPACA__SYMBOLS=["AAPL", "GOOGL", "MSFT"]

# Risk settings (all optional — defaults shown)
# RISK__MAX_POSITION_PCT=0.05
# RISK__MAX_DAILY_LOSS_PCT=0.02

# Strategy settings (optional)
# STRATEGY__INITIAL_CAPITAL=100000.0

# Database path (optional)
# DB_PATH=trading.db
